{
  "expo": {
    "name": "Qlaim",
    "slug": "prime",
    "description": "Qlaim mobile app for managing gigs and getting paid.",
    "scheme": "qlaim",
    "primaryColor": "#2CA24D",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#2CA24D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "dev.qlaim.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2CA24D"
      },
      "package": "dev.qlaim.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Qlaim to access your Face ID biometric data."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Qlaim to use your camera to capture required assignment proof photos.",
          "photosPermission": "Allow Qlaim to access your photo library to upload assignment proof photos."
        }
      ],
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "a95c8c6d-37e8-4e12-a500-328393c672c1"
      }
    },
    "owner": "kkinsey0",
    "updates": {
      "url": "https://u.expo.dev/a95c8c6d-37e8-4e12-a500-328393c672c1"
    }
  }
}
